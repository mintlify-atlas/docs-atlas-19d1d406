  "keyFeatures": [
    "AI-powered browser automation with human-like navigation",
    "Self-evolving UI/UX based on real user behavior analytics",
    "Multiple modes: CLI, programmatic API, and HTTP server",
    "Real-time dashboard for monitoring agent sessions",
    "Hybrid DOM and coordinate-based automation",
    "Visual overlays for reasoning, timing, and analytics tracking",
    "Support for multiple AI models (Gemini, Claude, OpenAI)",
    "MCP integration support for extended capabilities"
  ],
  "publicApiSurface": [
    "BrowserAgent class - Main automation engine",
    "Analyst class - Analyzes behavior and generates improvements",
    "darwin init - Initialize configuration",
    "darwin run - Execute automation tasks",
    "darwin config - Manage settings",
    "darwin evolve - Full evolution pipeline",
    "POST /api/run - Run agent via HTTP",
    "POST /api/evolve - Trigger evolution pipeline",
    "GET /api/sessions - List agent sessions",
    "GET /api/stream/:sessionId - Stream session logs (SSE)",
    "loadConfig() - Load configuration file",
    "createDefaultConfig() - Create default config",
    "startDarwin() - Start API server"
  ]
